       <div class="module-number">
        Módulo 3
       </div>
       <div class="module-title">
        Revolução Digital
       </div>
       <div class="module-description">
        Computadores, internet e transformação digital
       </div><span class="module-status">🔒 Bloqueado</span>
      </div>
      <div class="module-card locked" onclick="showLockedMessage()"><span class="module-icon">🤖</span>
       <div class="module-number">
        Módulo 4
