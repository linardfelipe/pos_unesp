<html lang="pt-BR">
 <head>

  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Missão Industrial</title>
  <script src="/_sdk/data_sdk.js"></script>
  <script src="/_sdk/element_sdk.js"></script>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="">
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html, body {
      height: 100%;
      box-sizing: border-box;
    }

    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background: linear-gradient(135deg, #8B4513 0%, #D2691E 100%);
      color: #2d3748;
      overflow-x: hidden;
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 12px;
      min-height: 100%;
    }

    /* Header */
    header {
      background: rgba(255, 255, 255, 0.95);
      padding: 16px 24px;
      border-radius: 12px;
      box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
      margin-bottom: 16px;
      backdrop-filter: blur(10px);
    }

    .header-content {
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 16px;
    }

    .logo-section {
      cursor: pointer;
    }

    .logo-container {
      display: flex;
      align-items: center;
      gap: 20px;
    }

    .factory-illustration {
      flex-shrink: 0;
    }

    .logo-section h1 {
      font-size: 24px;
      color: #8B4513;
      margin-bottom: 2px;
    }

    .logo-section p {
      color: #718096;
      font-size: 12px;
    }

    .back-btn {
      padding: 10px 20px;
      background: linear-gradient(135deg, #8B4513 0%, #D2691E 100%);
      color: white;
      border: none;
      border-radius: 8px;
      font-size: 13px;
      font-weight: bold;
      cursor: pointer;
      transition: all 0.3s ease;
      display: none;
    }

    .back-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 16px rgba(139, 69, 19, 0.4);
    }

    .progress-section {
      display: flex;
      gap: 24px;
      align-items: center;
    }

    .stat-box {
      text-align: center;
      padding: 10px 16px;
      background: linear-gradient(135deg, #8B4513 0%, #D2691E 100%);
      border-radius: 10px;
      color: white;
    }

    .stat-box .label {
      font-size: 11px;
      opacity: 0.9;
      margin-bottom: 2px;
    }

    .stat-box .value {
      font-size: 20px;
      font-weight: bold;
    }

    /* Main Content */
    .content-area {
      background: rgba(255, 255, 255, 0.95);
      padding: 20px;
      border-radius: 12px;
      box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
      margin-bottom: 16px;
    }

    .page {
      display: none;
    }

    .page.active {
      display: block;
      animation: fadeIn 0.5s ease;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* Home Page - Module Selection */
    .modules-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 14px;
      margin-top: 20px;
    }

    .module-card {
      background: linear-gradient(135deg, #FFF8DC 0%, #FFE4B5 100%);
      padding: 16px;
      border-radius: 10px;
      border: 2px solid #D2691E;
      cursor: pointer;
      transition: all 0.3s ease;
      position: relative;
      overflow: hidden;
    }

    .module-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 3px;
      background: linear-gradient(135deg, #8B4513 0%, #D2691E 100%);
      transform: scaleX(0);
      transition: transform 0.3s ease;
    }

    .module-card:hover:not(.locked) {
      transform: translateY(-3px);
      box-shadow: 0 8px 20px rgba(139, 69, 19, 0.3);
      border-color: #8B4513;
    }

    .module-card:hover:not(.locked)::before {
      transform: scaleX(1);
    }

    .module-card.locked {
      opacity: 0.6;
      cursor: not-allowed;
      background: #f1f3f5;
    }

    .module-card.locked:hover {
      transform: none;
    }

    .module-icon {
      font-size: 36px;
      margin-bottom: 8px;
      display: block;
    }

    .module-number {
      font-size: 11px;
      font-weight: bold;
      color: #8B4513;
      margin-bottom: 4px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .module-title {
      font-size: 16px;
      font-weight: bold;
      color: #2d3748;
      margin-bottom: 4px;
      line-height: 1.2;
    }

    .module-description {
      font-size: 12px;
      color: #718096;
      line-height: 1.4;
      margin-bottom: 8px;
    }

    .module-status {
      display: inline-block;
      padding: 4px 10px;
      background: rgba(139, 69, 19, 0.1);
      color: #8B4513;
      border-radius: 6px;
      font-size: 11px;
      font-weight: 600;
      margin-top: 6px;
    }

    .module-card.locked .module-status {
      background: #e2e8f0;
      color: #a0aec0;
    }

    /* Welcome Section */
    .welcome-hero {
      text-align: center;
      padding: 20px 16px;
    }

    .welcome-hero h2 {
      font-size: 26px;
      color: #8B4513;
      margin-bottom: 10px;
    }

    .welcome-hero p {
      font-size: 14px;
      color: #4a5568;
      line-height: 1.5;
      margin-bottom: 12px;
      max-width: 800px;
      margin-left: auto;
      margin-right: auto;
    }

    .methodology-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 12px;
      margin-top: 20px;
    }

    .method-card {
      background: linear-gradient(135deg, #FFF8DC 0%, #FFE4B5 100%);
      padding: 16px;
      border-radius: 10px;
      text-align: center;
      transition: transform 0.3s ease;
      border: 2px solid #D2691E;
    }

    .method-card:hover {
      transform: translateY(-3px);
    }

    .method-card .icon {
      font-size: 36px;
      margin-bottom: 8px;
    }

    .method-card h3 {
      color: #8B4513;
      margin-bottom: 6px;
      font-size: 16px;
    }

    .method-card p {
      color: #718096;
      font-size: 12px;
      line-height: 1.4;
    }

    /* Module Content */
    .module-header {
      text-align: center;
      margin-bottom: 20px;
      padding-bottom: 16px;
      border-bottom: 2px solid #8B4513;
    }

    .module-header h2 {
      font-size: 24px;
      color: #8B4513;
      margin-bottom: 8px;
    }

    .module-header p {
      font-size: 13px;
      color: #718096;
    }

    /* Video Section */
    .video-container {
      margin: 20px 0;
      border-radius: 10px;
      overflow: hidden;
      box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
    }

    /* Interactive Map */
    .map-container {
      margin: 20px 0;
      background: #FFF8DC;
      border-radius: 10px;
      padding: 16px;
      border: 2px solid #D2691E;
    }

    .map-placeholder {
      background: linear-gradient(135deg, #FFE4B5 0%, #FFDAB9 100%);
      height: 350px;
      border-radius: 8px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      position: relative;
      overflow: hidden;
    }

    .map-marker {
      position: absolute;
      width: 36px;
      height: 36px;
      background: #8B4513;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-size: 18px;
      cursor: pointer;
      transition: all 0.3s ease;
      box-shadow: 0 3px 10px rgba(139, 69, 19, 0.4);
    }

    .map-marker:hover {
      transform: scale(1.2);
      box-shadow: 0 5px 14px rgba(139, 69, 19, 0.6);
    }

    /* Infographic */
    .infographic {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      gap: 12px;
      margin: 20px 0;
    }

    .info-card {
      background: linear-gradient(135deg, #FFF8DC 0%, #FFE4B5 100%);
      padding: 16px;
      border-radius: 10px;
      text-align: center;
      border-left: 3px solid #8B4513;
      transition: all 0.3s ease;
    }

    .info-card:hover {
      transform: translateX(3px);
      box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
    }

    .info-card .number {
      font-size: 28px;
      font-weight: bold;
      color: #8B4513;
      margin-bottom: 6px;
    }

    .info-card .label {
      font-size: 12px;
      color: #4a5568;
      font-weight: 600;
    }

    /* Quiz Section */
    .quiz-container {
      margin: 20px 0;
    }

    .question-card {
      background: #f7fafc;
      padding: 24px;
      border-radius: 12px;
      margin-bottom: 24px;
      border-left: 4px solid #667eea;
    }

    .question-card h3 {
      color: #2d3748;
      margin-bottom: 16px;
      font-size: 18px;
    }

    .options {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .option-btn {
      padding: 16px;
      background: white;
      border: 2px solid #e2e8f0;
      border-radius: 8px;
      text-align: left;
      cursor: pointer;
      transition: all 0.3s ease;
      font-size: 15px;
      color: #4a5568;
    }

    .option-btn:hover {
      border-color: #667eea;
      background: #f0f4ff;
      transform: translateX(5px);
    }

    .option-btn.selected {
      border-color: #667eea;
      background: #e0e7ff;
      font-weight: 600;
    }

    .option-btn.correct {
      border-color: #48bb78;
      background: #c6f6d5;
      color: #22543d;
    }

    .option-btn.incorrect {
      border-color: #f56565;
      background: #fed7d7;
      color: #742a2a;
    }

    .submit-quiz-btn {
      padding: 14px 32px;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      border: none;
      border-radius: 8px;
      font-size: 16px;
      font-weight: bold;
      cursor: pointer;
      margin-top: 16px;
      transition: all 0.3s ease;
    }

    .submit-quiz-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 20px rgba(102, 126, 234, 0.4);
    }

    .submit-quiz-btn:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }

    /* Results */
    .results-container {
      background: linear-gradient(135deg, #f6f8fb 0%, #e9ecef 100%);
      padding: 32px;
      border-radius: 12px;
      text-align: center;
      margin-top: 24px;
    }

    .results-container h3 {
      font-size: 28px;
      color: #667eea;
      margin-bottom: 16px;
    }

    .score-display {
      font-size: 48px;
      font-weight: bold;
      color: #764ba2;
      margin: 20px 0;
    }

    .medal {
      font-size: 80px;
      margin: 20px 0;
      animation: bounce 1s ease infinite;
    }

    @keyframes bounce {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-10px); }
    }

    .next-module-btn {
      padding: 14px 32px;
      background: linear-gradient(135deg, #48bb78 0%, #38a169 100%);
      color: white;
      border: none;
      border-radius: 8px;
      font-size: 16px;
      font-weight: bold;
      cursor: pointer;
      margin-top: 16px;
      transition: all 0.3s ease;
    }

    .next-module-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 20px rgba(72, 187, 120, 0.4);
    }

    /* Toast Notification */
    .toast {
      position: fixed;
      bottom: 24px;
      right: 24px;
      background: #2d3748;
      color: white;
      padding: 16px 24px;
      border-radius: 8px;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
      display: none;
      z-index: 1000;
      animation: slideIn 0.3s ease;
    }

    /* Visit Counter */
    .visit-counter {
      position: fixed;
      bottom: 24px;
      right: 24px;
      background: linear-gradient(135deg, #8B4513 0%, #D2691E 100%);
      color: white;
      padding: 12px 20px;
      border-radius: 50px;
      font-size: 14px;
      font-weight: bold;
      box-shadow: 0 6px 20px rgba(139, 69, 19, 0.4);
      display: flex;
      align-items: center;
      gap: 8px;
      z-index: 999;
      border: 2px solid rgba(255, 255, 255, 0.3);
      backdrop-filter: blur(10px);
    }

    .visit-counter span {
      font-size: 18px;
      font-weight: bold;
      min-width: 40px;
      text-align: center;
    }

    .toast.show {
      display: block;
    }

    @keyframes slideIn {
      from { transform: translateX(400px); }
      to { transform: translateX(0); }
    }

    /* Medal Display */
    .medal-display {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
      gap: 20px;
      margin-top: 24px;
    }

    .medal-item {
      background: linear-gradient(135deg, #f6f8fb 0%, #e9ecef 100%);
      padding: 20px;
      border-radius: 12px;
      text-align: center;
      transition: all 0.3s ease;
      border: 2px solid #e2e8f0;
      opacity: 0.4;
      filter: grayscale(100%);
    }

    .medal-item.unlocked {
      opacity: 1;
      filter: grayscale(0%);
      border-color: #667eea;
      box-shadow: 0 8px 24px rgba(102, 126, 234, 0.3);
      animation: medalUnlock 0.6s ease;
    }

    @keyframes medalUnlock {
      0% { transform: scale(0.8) rotate(-10deg); opacity: 0; }
      50% { transform: scale(1.1) rotate(5deg); }
      100% { transform: scale(1) rotate(0deg); opacity: 1; }
    }

    .medal-item:hover.unlocked {
      transform: translateY(-5px) scale(1.05);
      box-shadow: 0 12px 32px rgba(102, 126, 234, 0.4);
    }

    .medal-icon-container {
      width: 80px;
      height: 80px;
      margin: 0 auto 12px;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 4px 16px rgba(102, 126, 234, 0.3);
    }

    .medal-item.unlocked .medal-icon-container {
      animation: pulse 2s ease infinite;
    }

    @keyframes pulse {
      0%, 100% { transform: scale(1); }
      50% { transform: scale(1.05); }
    }

    .medal-icon {
      font-size: 40px;
    }

    .medal-name {
      font-weight: bold;
      color: #2d3748;
      margin-bottom: 4px;
      font-size: 14px;
    }

    .medal-description {
      font-size: 12px;
      color: #718096;
    }

    /* Responsive */
    @media (max-width: 768px) {
      .header-content {
        flex-direction: column;
        text-align: center;
      }

      .logo-container {
        flex-direction: column;
        gap: 12px;
      }

      .progress-section {
        width: 100%;
        justify-content: center;
      }

      .logo-section h1 {
        font-size: 24px;
      }

      .welcome-hero h2 {
        font-size: 28px;
      }

      .map-placeholder {
        height: 250px;
      }
    }
  </style>
  <style>@view-transition { navigation: auto; }</style>
  <script src="https://cdn.tailwindcss.com" type="text/javascript"></script>
  <script src="https://cdn.tailwindcss.com/3.4.17" type="text/javascript"></script>
 </head>
