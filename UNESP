    <div class="header-content">
     <div class="logo-section" onclick="goToHome()">
      <div class="logo-container">
       <svg class="factory-illustration" width="80" height="80" viewbox="0 0 200 200" xmlns="http://www.w3.org/2000/svg"><!-- Factory Building --> <rect x="40" y="80" width="120" height="100" fill="#8B4513" stroke="#654321" stroke-width="3" /> <!-- Windows --> <rect x="55" y="95" width="20" height="25" fill="#FFD700" opacity="0.8" /> <rect x="90" y="95" width="20" height="25" fill="#FFD700" opacity="0.8" /> <rect x="125" y="95" width="20" height="25" fill="#FFD700" opacity="0.8" /> <rect x="55" y="135" width="20" height="25" fill="#FFD700" opacity="0.8" /> <rect x="90" y="135" width="20" height="25" fill="#FFD700" opacity="0.8" /> <rect x="125" y="135" width="20" height="25" fill="#FFD700" opacity="0.8" /> <!-- Door --> <rect x="85" y="150" width="30" height="30" fill="#654321" stroke="#4a2f1a" stroke-width="2" /> <!-- Chimney 1 --> <rect x="60" y="30" width="20" height="50" fill="#8B4513" stroke="#654321" stroke-width="2" /> <rect x="57" y="25" width="26" height="8" fill="#654321" /> <!-- Chimney 2 --> <rect x="120" y="40" width="20" height="40" fill="#8B4513" stroke="#654321" stroke-width="2" /> <rect x="117" y="35" width="26" height="8" fill="#654321" /> <!-- Smoke from chimneys (animated) --> <ellipse cx="70" cy="20" rx="8" ry="6" fill="#A9A9A9" opacity="0.6">
